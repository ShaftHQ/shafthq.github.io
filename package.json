{
  "name": "shaft-user-guide",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "node scripts/build-autobot-index.mjs && node scripts/build-llms-txt.mjs && docusaurus build && node scripts/prune-search-index.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:docs && npm run test:homepage && npm run test:history && npm run test:release-template",
    "test:history": "node tests/chat-history.test.js",
    "test:homepage": "node tests/homepage-performance.test.js",
    "test:docs": "node tests/docs-loader.test.js && node tests/cloudflare-autobot.test.js && node tests/enhanced-instruction.test.js && node tests/properties-catalog.test.js && node tests/generate-properties-catalog-regex.test.js && node tests/properties-list-coverage.test.js && node tests/docs-quality.test.js && node tests/design-contrast.test.js && node scripts/check-doc-duplicates.mjs",
    "test:api": "node tests/chatbot-api.test.js",
    "test:e2e": "npm run test:shaft",
    "test:playwright": "npx playwright test",
    "test:release-template": "node tests/release-blog-template.test.js",
    "test:shaft": "node scripts/run-shaft-tests.mjs",
    "verify-models": "node scripts/verify-models.js",
    "build:llms": "node scripts/build-llms-txt.mjs",
    "generate:properties-catalog": "node scripts/generate-properties-catalog.mjs"
  },
  "dependencies": {
    "@cmfcmf/docusaurus-search-local": "^2.0.1",
    "@docusaurus/core": "^3.10.2",
