{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "node_modules/@docusaurus/module-type-aliases/src/index.d.ts",
    "node_modules/@docusaurus/theme-classic/src/theme-classic.d.ts"
  ],
  "exclude": ["build", ".docusaurus"]
}
